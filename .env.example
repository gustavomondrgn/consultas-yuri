# ── Notion ───────────────────────────────────────────────────────────────────
# Use as MESMAS credenciais do form-potencial-financeiro (base
# "Entrega - Diagnóstico Potencial de Riqueza"). Assim é impossível escrever no
# banco errado (Bússola / Raio-X).
NOTION_API_KEY=
NOTION_DATA_SOURCE_ID=
# Alternativa, se não usar data source:
# NOTION_DATABASE_ID=
NOTION_VERSION=2025-09-03

# Status que DISPARA o agente (fluxo: ... Texto feito → Entregar → Entregue).
NOTION_STATUS_TRIGGER=Entregue

# ── Cronômetro por pessoa ────────────────────────────────────────────────────
COUNTDOWN_HOURS=48

# ── Agente ───────────────────────────────────────────────────────────────────
# Segredo que protege POST/GET /consultas/api/agent/gerar-links
AGENT_SECRET=
# Base pública usada pra montar o link ?u= que vai no Notion
PUBLIC_SITE_URL=https://yuridosanjos.com.br
