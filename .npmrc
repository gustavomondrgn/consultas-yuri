# Garante que `npm ci` instala devDependencies mesmo quando NODE_ENV=production
# está exposto no ambiente de build (cenário do Coolify/nixpacks).
# O Next/Tailwind/TS são devDeps mas o `next build` precisa delas.
# Esta config sobrescreve o default de omit=dev que o npm aplica quando
# NODE_ENV=production. Não afeta runtime — o `npm prune --omit=dev` posterior
# do nixpacks continua removendo as devDeps do bundle de produção.
production=false
